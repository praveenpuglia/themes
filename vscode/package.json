  "version": "0.1.0",
  "publisher": "praveenpuglia",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/praveenpuglia/themes.git"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Soft Day",
        "uiTheme": "vs",
