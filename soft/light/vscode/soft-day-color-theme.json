  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment", "string.comment"],
      "settings": { "foreground": "#8a93a0", "fontStyle": "italic" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": { "foreground": "#2c333d" }
    },
    {
      "name": "Variable language (this, self, super)",
      "scope": ["variable.language", "variable.language.this"],
      "settings": { "foreground": "#c1453a", "fontStyle": "italic" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter", "meta.function.parameters"],
      "settings": { "foreground": "#9a6a00" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "variable.other.object.property", "meta.object-literal.key"],
      "settings": { "foreground": "#2b6fb8" }
    },
    {
      "name": "Constants & enums",
      "scope": ["variable.other.constant", "variable.other.enummember", "constant.other"],
      "settings": { "foreground": "#1f8a8a" }
    },
    {
      "name": "Colors / language constants (true,false,null)",
      "scope": ["constant.language", "constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#9b4bb3" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric", "constant.numeric.integer", "constant.numeric.float"],
      "settings": { "foreground": "#9b4bb3" }
    },
    {
      "name": "Character / escape constants",
      "scope": ["constant.character", "constant.character.escape", "constant.other.placeholder"],
